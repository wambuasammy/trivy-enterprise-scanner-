# ============================================================================
# Trivy Enterprise Image Scanner - .gitignore
# ============================================================================

# ----------------------------------------------------------------------------
# Docker Image Archives
# ----------------------------------------------------------------------------
# Docker image TAR files can be very large and should not be committed.
images/*.tar

# ----------------------------------------------------------------------------
# Generated Reports
# ----------------------------------------------------------------------------
# All scan artifacts are generated under reports/<image-name>/
reports/

# ----------------------------------------------------------------------------
# Log Files
# ----------------------------------------------------------------------------
scan.log
*.log

# ----------------------------------------------------------------------------
# Packaged Archives
# ----------------------------------------------------------------------------
*.zip

# ----------------------------------------------------------------------------
# Trivy Cache (if ever stored inside the project)
# ----------------------------------------------------------------------------
.trivy/
cache/

# ----------------------------------------------------------------------------
# Temporary Files
# ----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*~

# ----------------------------------------------------------------------------
# Operating System Files
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ----------------------------------------------------------------------------
# Editor / IDE Files
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ----------------------------------------------------------------------------
# Python Cache (if helper scripts are added later)
# ----------------------------------------------------------------------------
__pycache__/
*.pyc

# ----------------------------------------------------------------------------
# ShellCheck / Testing Artifacts
# ----------------------------------------------------------------------------
shellcheck.out
test-output/

# ============================================================================
# Files Intentionally Included in Git
# ============================================================================
# trivy-scan
# config.sh
# README.md
# .gitignore
# ============================================================================